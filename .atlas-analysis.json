  "keyFeatures": [
    "Persistent drawing storage backed by SQLite",
    "Real-time collaboration via WebSocket (Socket.IO)",
    "Collections and drag-and-drop drawing organization",
    "Full-text drawing search",
    "Scoped internal and external link sharing with passphrase protection",
    "Export/import in plain .excalidraw format for backup",
    "Multi-user authentication: local email/password and OIDC (hybrid or enforced)",
    "Admin dashboard with user management and audit logging",
    "Docker-based self-hosted deployment with Docker Hub images",
    "In-app update notifier against GitHub Releases"
  ],
